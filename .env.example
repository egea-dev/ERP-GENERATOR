# ============================================
# ERP GENERATOR - Variables de Entorno
# ============================================
# Copia este archivo a .env y ajusta los valores

# --------------------------------------------
# BASE DE DATOS
# --------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-contraseña-por-una-segura
POSTGRES_DB=erp_generator

# --------------------------------------------
# BACKEND
# --------------------------------------------
# Clave secreta para JWT (genera una aleatoria en producción)
JWT_SECRET=tu-clave-secreta-ultra-segura-aqui

# Origen CORS permitido (usa la URL de tu dominio en producción)
CORS_ORIGIN=*

# Puerto del backend (no cambiar si usas docker-compose)
PORT=3001

# Proxy privado para la API externa de envios
# Estas variables deben vivir solo en el backend (por ejemplo, apps/backend/.env)
TARIFAS_API_BASE_URL=http://localhost:8001/api/external/v1
TARIFAS_API_KEY=dev-external-api-key

# --------------------------------------------
# FRONTEND
# --------------------------------------------
# URL de la API del backend (ajusta según tu dominio)
# En desarrollo local: http://localhost:3001/api
# En producción con Coolify: http://erp-backend:3001/api (interno) o https://tu-dominio.com/api
VITE_API_URL=http://localhost:3001/api

# --------------------------------------------
# LLM / IA (opcional)
# --------------------------------------------
DEFAULT_LLM_PROVIDER=lmstudio
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.70

# URL de LM Studio (ajusta si usas otro proveedor)
LMSTUDIO_URL=http://host.docker.internal:1234/v1
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
