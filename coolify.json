{
  "$schema": "https://coolify.io/nixpacks",
  "build": {
    "nixpacks": true
  },
  "services": {
    "backend": {
      "type": "node",
      "root": "apps/backend",
      "startCommand": "node index.js",
      "port": 3001,
      "env": {
        "DATABASE_URL": "postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/erp_generator",
        "JWT_SECRET": "${JWT_SECRET}",
        "CORS_ORIGIN": "${CORS_ORIGIN:-*}",
        "DEFAULT_LLM_PROVIDER": "${DEFAULT_LLM_PROVIDER:-lmstudio}",
        "RAG_TOP_K": "${RAG_TOP_K:-5}",
        "RAG_SIMILARITY_THRESHOLD": "${RAG_SIMILARITY_THRESHOLD:-0.70}",
        "LMSTUDIO_URL": "${LMSTUDIO_URL:-http://host.docker.internal:1234/v1}",
        "EMBEDDING_MODEL": "${EMBEDDING_MODEL:-text-embedding-nomic-embed-text-v1.5}"
      }
    },
    "frontend": {
      "type": "node",
      "root": "apps/frontend",
      "buildCommand": "npm run build",
      "startCommand": "npx serve -s dist -l ${PORT:-3000}",
      "port": 3000,
      "env": {
        "VITE_API_URL": "${VITE_API_URL}"
      }
    }
  }
}
